// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Admin {
  id            Int      @id @default(autoincrement())
  username      String   @db.VarChar(255)
  phone         String   @unique @db.VarChar(12)
  password      String   @db.VarChar(128)
  email         String   @unique @default("") @db.VarChar(128)
  date_joined   DateTime @db.DateTime(6)
  last_login    DateTime @db.DateTime(6)
  is_subscribed Boolean
  tier          UserTier

  Project    Project[]
  RouteGroup RouteGroup[]
  Route      Route[]

  Organization Organization[]
}

model Organization {
  id                String       @id @unique @default(uuid())
  name     String
  admin_id Int
  Admin    Admin  @relation(fields: [admin_id], references: [id])

  Project Project[] 
}

model Project {
  id                String       @id @unique @default(uuid())
  name              String       @db.VarChar(255)
  admin_id          Int
  Admin             Admin        @relation(fields: [admin_id], references: [id])
  organization_id String
  Organization      Organization @relation(fields: [organization_id], references: [id])

  RouteGroup   RouteGroup[]
  Route        Route[]
  Secret       Secret[]
  Collection   Collection[]
  RequestModel RequestModel[]
  ApiEndpoint  ApiEndpoint[]
  Api          Api[]

  @@unique([name, organization_id])
}

model RouteGroup {
  id          Int    @id @default(autoincrement())
  parentRoute String
  project_id  String
  admin_id    Int

  Admin   Admin   @relation(fields: [admin_id], references: [id])
  Project Project @relation(fields: [project_id], references: [id])

  Route Route[]

  @@unique([parentRoute, project_id])
}

model Route {
  id             Int     @id @default(autoincrement())
  route          String
  schema_record  String?
  route_group_id Int
  project_id     String
  admin_id       Int

  Admin      Admin      @relation(fields: [admin_id], references: [id])
  Project    Project    @relation(fields: [project_id], references: [id])
  RouteGroup RouteGroup @relation(fields: [route_group_id], references: [id])

  @@unique([route, route_group_id])
}

model Secret {
  id         Int        @id @default(autoincrement())
  project_id String
  key        String
  value      String
  type       SecretType
  Project    Project    @relation(fields: [project_id], references: [id])

  @@unique([project_id, key])
}

model Collection {
  id               Int    @id @default(autoincrement())
  project_id       String
  name             String
  default_endpoint String
  description      String
  schema           Json

  Project Project @relation(fields: [project_id], references: [id])

  @@unique([name, project_id])
}

model RequestModel {
  id                Int              @id @default(autoincrement())
  project_id        String
  name              String
  type              RequestModelType
  schema            Json
  Project           Project          @relation(fields: [project_id], references: [id])
  ApiEndpointBody   ApiEndpoint?    @relation(map: "ApiEndpointBody",name: "ApiEndpointToRequestBody")
  ApiEndpointParams ApiEndpoint?    @relation(map: "ApiEndpointParams",name: "ApiEndpointToQueryParams")

  @@unique([name, project_id])
}

model Api {
  id         Int    @id @default(autoincrement())
  project_id String
  template String?
  endpoint   String
  name       String

  Project Project @relation(fields: [project_id], references: [id])
  ApiTemplate ApiTemplate? @relation(fields: [template], references: [name])

  ApiEndpoint ApiEndpoint[]
}

model ApiEndpoint {
  id              Int            @id @default(autoincrement())
  project_id      String
  api_id          Int
  endpoint        String
  request_body_id Int? @unique
  query_params_id Int? @unique
  authentication  Boolean
  definition      Json
  method          HttpMethodType

  API     Api          @relation(fields: [api_id], references: [id])
  Project         Project      @relation(fields: [project_id], references: [id])
  RequestBody RequestModel? @relation(name: "ApiEndpointToRequestBody", fields: [request_body_id], references: [id])
  QueryParams RequestModel? @relation(name: "ApiEndpointToQueryParams", fields: [query_params_id], references: [id])

  @@unique([endpoint, project_id, method])
}

model ApiTemplate {
  id       Int    @id @default(autoincrement())
  name     String 
  template Json

  Api Api[]

  @@unique([name])
}

model Database {
  project_id String @id
  name       String
}

enum RequestModelType {
  request_body
  query_params
}

enum SecretType {
  database
  general
}

enum UserTier {
  trial
  premium
  super
}

enum HttpMethodType {
  GET
  POST
  PUT
  DELETE
  PATCH
}
